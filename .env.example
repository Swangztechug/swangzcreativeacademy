# Production: set NODE_ENV=production and use a strong AUTH_SECRET (e.g. openssl rand -hex 32)
# Database connection (PostgreSQL)
# Example: postgres://user:password@localhost:5432/swangz_academy
DATABASE_URL=postgres://user:password@localhost:5432/swangz_academy

# Cloudflare R2 (for image uploads)
# R2_ENDPOINT example: https://<accountid>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
# Public URL base that serves files from the bucket (can be a custom domain/route)
# Example: https://media.yourdomain.com
R2_PUBLIC_BASE_URL=https://media.yourdomain.com

# Secret used to sign admin session cookies
AUTH_SECRET=change-me-to-a-long-random-string

# Redis (optional, for caching site content)
# Example: redis://default:password@host:port/0
REDIS_URL=redis://default:password@localhost:6379/0
